---

---

<section id='contact'>
	<div class='organized grid grid-cols-2 gap-16 h-140'>
		<aside
			class='p-10 h-full bg-brand-primary-07 text-brand-bright bg-[url(../images/noise.png),url(../images/landing/abstract.png)] bg-size-[auto,cover]'
		>
			<h2 class='heading-1'>Contact Us</h2>
			<p class='mt-3'>Reach out to us and we'll be with you shortly</p>
		</aside>

		<form class='order-first flex flex-col gap-6'>
			<span class='block'>
				<label for='' class='block mb-2'>Email</label><input
					class='block w-full py-2.5 px-5 placeholder:text-brand-neutral-05 border-brand-neutral-03 border'
					placeholder='Input Email Here'
				/>
			</span>
			<span class='block'
				><label for='' class='block mb-2'>Message</label><textarea
					placeholder='Write us a message'
					rows='8'
					class='block w-full resize-none py-2.5 px-5 border-brand-neutral-03 border placeholder:text-brand-neutral-05'
				></textarea></span
			>
			<div><button class='btn-primary'>Send Message</button></div>
		</form>
	</div>
</section>
